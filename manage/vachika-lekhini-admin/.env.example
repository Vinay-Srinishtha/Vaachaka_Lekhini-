# Runtime database URL. Use the provider's pooled URL on Vercel.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Admin dashboard JWT signing secret. Generate with: openssl rand -hex 32
SESSION_SECRET="replace-with-a-random-secret"

# Flutter user access/refresh JWT signing secret. Keep separate from SESSION_SECRET.
USER_JWT_SECRET="replace-with-a-different-random-secret"

# Production SMS OTP provider.
OTP_PROVIDER="2factor"
TWO_FACTOR_API_KEY="replace-with-provider-api-key"
TWO_FACTOR_TEMPLATE="OTPONLY"

# Used only by the one-time production seed command.
ADMIN_USERNAME="admin"
ADMIN_BOOTSTRAP_PASSWORD="replace-with-a-strong-password"
