		"@types/pg": "^8.20.0",
		"dotenv": "^17.4.2",
		"prisma": "^7.8.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1069.0",
		"@aws-sdk/s3-request-presigner": "^3.1069.0",
		"@lucide/svelte": "^1.16.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@tailwindcss/vite": "^4.3.0",
		"bcryptjs": "^3.0.3",
		"jose": "^6.2.3",
		"pg": "^8.21.0",
